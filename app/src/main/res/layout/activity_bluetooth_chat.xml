<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3F4F6">

    <!-- Custom Modern Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarChat"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2563EB"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Bluetooth Chat" />

    <!-- Connection Status Header -->
    <LinearLayout
        android:id="@+id/layoutChatStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status_bar"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <View
            android:id="@+id/viewChatStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@android:color/holo_green_dark"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvChatStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connected"
            android:textColor="#F3F4F6"
            android:fontFamily="sans-serif-medium"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Main Content Frame (Chat or Console Logs) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Chat Messages List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="visible" />

        <!-- Terminal Console Log Display -->
        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1F2937"
            android:padding="12dp"
            android:visibility="gone"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tvChatLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:textIsSelectable="true" />
                
                <ImageView
                    android:id="@+id/ivReceivedImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxHeight="420dp"
                    android:layout_marginTop="8dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    android:contentDescription="Received image" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Bottom Input and Action Panel -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <!-- Chat Mode Input Bar -->
            <LinearLayout
                android:id="@+id/layoutChatInputBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:visibility="visible">

                <!-- Attachment actions group -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btnChatFile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_file"
                        android:contentDescription="Send file" />

                    <ImageButton
                        android:id="@+id/btnChatCamera"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="Take photo" />

                    <ImageButton
                        android:id="@+id/btnChatGallery"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_gallery"
                        android:contentDescription="Send from gallery" />
                </LinearLayout>

                <!-- Pill styled text input field -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chat_input"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/etChatMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Type a message..."
                        android:inputType="textShortMessage"
                        android:maxLines="4"
                        android:background="@null"
                        android:textColor="#1F2937"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Modern Send Button -->
                <ImageButton
                    android:id="@+id/btnChatSend"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_chat_send_button"
                    android:src="@drawable/ic_send"
                    android:contentDescription="Send" />
            </LinearLayout>

            <!-- Console Log Mode Action Bar -->
            <LinearLayout
                android:id="@+id/layoutConsoleLogBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/btnChatClear"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:src="@drawable/ic_trash"
                    android:scaleType="centerInside"
                    android:contentDescription="Clear Logs" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
