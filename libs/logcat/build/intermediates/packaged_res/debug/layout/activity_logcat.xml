<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarLogcat"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:title="Logcat Viewer">

        <ImageButton
            android:id="@+id/btnStreamSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end"
            android:layout_marginEnd="12dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#FFFFFF"
            android:contentDescription="Stream Settings" />

    </androidx.appcompat.widget.Toolbar>

    <!-- Action Bar / Filter Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="#1E1E1E">

        <!-- Search Input -->
        <EditText
            android:id="@+id/etFilter"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Filter logs..."
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@android:drawable/edit_text"
            android:inputType="text"
            android:maxLines="1" />

        <!-- Toggle Auto Scroll Button -->
        <ImageButton
            android:id="@+id/btnToggleScroll"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#64B5F6"
            android:contentDescription="Toggle Auto Scroll" />

        <!-- Clear Button -->
        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#FF5252"
            android:contentDescription="Clear logs" />

        <!-- Share Button -->
        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_share"
            app:tint="#64B5F6"
            android:contentDescription="Share logs" />

        <!-- Refresh Button -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_sync"
            app:tint="#81C784"
            android:contentDescription="Refresh logs" />
    </LinearLayout>

    <!-- READ_LOGS Permission Warning Banner -->
    <LinearLayout
        android:id="@+id/layoutReadLogsWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/bg_warning_banner"
        android:foreground="?android:attr/selectableItemBackground"
        android:orientation="vertical"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D84315"
            android:textStyle="bold"
            android:textSize="12sp"
            android:text="⚠ READ_LOGS not granted — only this app's own logs are visible" />

        <TextView
            android:id="@+id/tvReadLogsCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#263238"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:text="adb shell pm grant hdisoft.app.cideploy android.permission.READ_LOGS" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#78909C"
            android:textSize="10sp"
            android:text="(Tap to copy command)" />

    </LinearLayout>

    <!-- Stream Status Bar -->
    <TextView
        android:id="@+id/tvStreamStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E2E2E"
        android:textColor="#81C784"
        android:textSize="12sp"
        android:padding="6dp"
        android:gravity="center"
        android:text="Stream Status: Log streaming stopped" />

    <!-- Connection URL Display Bar -->
    <LinearLayout
        android:id="@+id/layoutUrlDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#232323"
        android:foreground="?android:attr/selectableItemBackground"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvFullUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFB74D"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:text="ws://127.0.0.1:8082" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:text="(Click to copy)" />
    </LinearLayout>

    <!-- Content / Logs -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLogcat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:scrollbars="vertical" />

        <ProgressBar
            android:id="@+id/pbLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No logs found"
            android:textColor="#888888"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
