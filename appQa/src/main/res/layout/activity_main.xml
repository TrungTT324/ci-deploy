<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/qa_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QA Automation Hub"
            android:textColor="@color/qa_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage system permissions and control background automation tools."
            android:textColor="@color/qa_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Card 1: Accessibility -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/qa_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="1. Accessibility Service"
                    android:textColor="@color/qa_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISABLED"
                    android:textColor="@color/status_red"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required to automate clicks and text inputs on other apps. Android requires manual activation in Accessibility settings."
                android:textColor="@color/qa_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_grant_accessibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enable Accessibility"
                android:backgroundTint="@color/qa_accent"
                android:textColor="@color/qa_text" />
        </LinearLayout>

        <!-- Card 2: Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/qa_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2. Overlay Window"
                    android:textColor="@color/qa_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DENIED"
                    android:textColor="@color/status_red"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Allows displaying the floating action controller on top of other applications."
                android:textColor="@color/qa_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_grant_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Overlay Permission"
                android:backgroundTint="@color/qa_accent"
                android:textColor="@color/qa_text" />
        </LinearLayout>

        <!-- Card 3: QA Foreground Service -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/qa_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3. QA Control Service"
                    android:textColor="@color/qa_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOPPED"
                    android:textColor="@color/status_red"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/desc_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Launches the floating overlay controller and media capture engine. Will ask for Screen Capture approval on start."
                android:textColor="@color/qa_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_start_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Service"
                    android:backgroundTint="@color/qa_primary"
                    android:textColor="@color/qa_text"
                    android:layout_marginRight="4dp" />

                <Button
                    android:id="@+id/btn_stop_service"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop Service"
                    android:backgroundTint="#D50000"
                    android:textColor="@color/qa_text"
                    android:layout_marginLeft="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card 4: Web Report Server -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/qa_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4. Web Report Server"
                    android:textColor="@color/qa_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/status_webserver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFFLINE"
                    android:textColor="@color/status_red"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/desc_webserver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Web Server runs when the QA Service is active. Access it from your computer browser to view and download screenshots/videos."
                android:textColor="@color/qa_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/url_webserver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL: http://&lt;device_ip&gt;:8085/reports"
                android:textColor="@color/qa_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btn_start_webserver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start Server"
                    android:backgroundTint="@color/qa_accent"
                    android:textColor="@color/qa_text"
                    android:layout_marginRight="4dp" />

                <Button
                    android:id="@+id/btn_stop_webserver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop Server"
                    android:backgroundTint="#D50000"
                    android:textColor="@color/qa_text"
                    android:layout_marginLeft="4dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
